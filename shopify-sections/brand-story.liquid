<section class="brand-story" id="our-story">
  <div class="page-width">
    <div class="brand-story__grid">
      <div class="brand-story__media">
        {% if section.settings.image != blank %}
          {{ section.settings.image | image_url: width: 900 | image_tag: loading: 'lazy', class: 'brand-story__img' }}
        {% else %}
          <div class="brand-story__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {% endif %}
      </div>
      <div class="brand-story__content">
        {% if section.settings.subtitle != blank %}
          <span class="brand-story__subtitle">{{ section.settings.subtitle }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="brand-story__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="brand-story__text">{{ section.settings.text }}</div>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}" class="brand-story__button button button--secondary">
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .brand-story {
    padding: 5rem 0;
    background-color: var(--color-bg, #0a0a0a);
  }

  .brand-story__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  .brand-story__media {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius, 2px);
    aspect-ratio: 4 / 5;
  }

  .brand-story__img,
  .brand-story__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .brand-story__placeholder {
    background-color: var(--color-bg-card, #141414);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-story__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 480px;
  }

  .brand-story__subtitle {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: 0.68rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent, #e8d5b5);
    font-weight: 500;
  }

  .brand-story__heading {
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: clamp(1.8rem, 3vw, 2.8rem);
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    color: var(--color-text, #f5f5f0);
    margin: 0;
  }

  .brand-story__text {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text-muted, #a0a09a);
    font-weight: 300;
  }

  .brand-story__text p {
    margin: 0 0 1rem;
  }

  .brand-story__button {
    align-self: flex-start;
    margin-top: 0.5rem;
    text-decoration: none;
    display: inline-block;
    padding: 1rem 2.5rem;
    font-family: var(--font-heading, 'Space Grotesk', sans-serif);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid var(--color-border, #2a2a2a);
    color: var(--color-text, #f5f5f0);
    background: transparent;
    transition: all 0.3s ease;
  }

  .brand-story__button:hover {
    border-color: var(--color-accent, #e8d5b5);
    color: var(--color-accent, #e8d5b5);
  }

  @media screen and (max-width: 749px) {
    .brand-story__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .brand-story__media {
      aspect-ratio: 3 / 4;
    }

    .brand-story {
      padding: 3rem 0;
    }
  }
</style>

{% schema %}
{
  "name": "Brand Story",
  "tag": "section",
  "class": "section-brand-story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built Different"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Body text",
      "default": "<p>ONHIZM was born from the belief that streetwear should feel as premium as it looks. Every piece is designed with intention — from fabric selection to final stitch.</p><p>We don't follow trends. We set the standard.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Brand Story"
    }
  ]
}
{% endschema %}
